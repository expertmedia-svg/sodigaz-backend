# Configuration de base de données pour le développement local
DATABASE_URL=sqlite:///./dev.db

# Sage X3 Integration - MODE MOCK (TESTS)
SAGE_X3_PUSH_MODE=mock
SAGE_X3_BASE_URL=https://sage-api.example.com
SAGE_X3_API_KEY=mock-api-key-for-testing
SAGE_X3_TIMEOUT_SECONDS=15
SAGE_X3_AUTH_SCHEME=bearer
SAGE_X3_AUTH_HEADER=Authorization
SAGE_X3_DELIVERY_ENDPOINT=/deliveries
SAGE_X3_STOCK_MOVEMENT_ENDPOINT=/stock-movements
SAGE_X3_HEALTH_ENDPOINT=/health
INTEGRATION_OUTBOX_MAX_RETRIES=3
SAGE_X3_INBOUND_TOKEN=test-token-123
